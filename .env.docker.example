# ================================================================
# Betpreneur Backend - Docker Environment Variables
# ================================================================
# Copy this file to .env and update values
# cp .env.docker.example .env
# ================================================================

# ------------------------------
# Django
# ------------------------------
DJANGO_SECRET_KEY=change-me-in-production-use-random-string
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,your-domain.com
DJANGO_SETTINGS_MODULE=config.settings
CSRF_TRUSTED_ORIGINS=https://your-domain.com

# ------------------------------
# Database
# ------------------------------
DB_ENGINE=django.db.backends.postgresql
DB_NAME=betpreneur
DB_USER=betpreneur
DB_PASSWORD=change-me-strong-password
DB_HOST=db
DB_PORT=5432

# ------------------------------
# External APIs
# ------------------------------
# API-Football
APS_KEY=
APS_MAX_FIXTURES=90

# Gemini analyst mode
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Resend (email delivery)
RESEND_API_KEY=
RESEND_FROM_NAME=Betpreneur
RESEND_FROM_EMAIL_PREFIX=support
RESEND_FROM_EMAIL_DOMAIN=betpreneur.ng
RESEND_FROM_EMAIL=support@betpreneur.ng

# ------------------------------
# Google Drive Integration
# ------------------------------
KEY_FILE=
SHEET_NAME=GrindAlgo Tracker
DRIVE_FOLDER=GrindAlgo Reports
EMAIL_RECIPIENT=
GMAIL_APP_PASSWORD=

# ------------------------------
# Celery Automation
# ------------------------------
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0
ALGO_GENERATE_HOUR=0
ALGO_GENERATE_MINUTE=5
ALGO_SETTLE_HOUR=6
ALGO_SETTLE_MINUTE=30
ALGO_AUDITOR_DAY=1
ALGO_AUDITOR_HOUR=8
ALGO_AUDITOR_MINUTE=0
CELERY_WORKER_CONCURRENCY=2

# ------------------------------
# Application
# ------------------------------
FRONTEND_URL=http://localhost:3000
CORS_ALLOWED_ORIGINS=http://localhost:3000
TZ=Africa/Lagos

# ------------------------------
# Ports
# ------------------------------
APP_PORT=8000
