# ================================================================
# Betpreneur Backend - Docker Environment Variables
# ================================================================
# Copy this file to .env and update values
# cp .env.docker.example .env
# ================================================================

# ------------------------------
# Django
# ------------------------------
DJANGO_SECRET_KEY=change-me-in-production-use-random-string
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,your-domain.com
DJANGO_SETTINGS_MODULE=config.settings

# ------------------------------
# Database
# ------------------------------
DB_ENGINE=django.db.backends.postgresql
DB_NAME=betpreneur
DB_USER=betpreneur
DB_PASSWORD=change-me-strong-password
DB_HOST=db
DB_PORT=5432

# ------------------------------
# External APIs
# ------------------------------
# Football Data API (free tier)
FD_TOKEN=

# API-Football (paid)
APS_KEY=

# The Odds API
ODDS_KEY=

# Resend (email delivery)
RESEND_API_KEY=
RESEND_FROM_NAME=Betpreneur
RESEND_FROM_EMAIL_PREFIX=support
RESEND_FROM_EMAIL_DOMAIN=betpreneur.ng
RESEND_FROM_EMAIL=support@betpreneur.ng

# ------------------------------
# Google Drive Integration
# ------------------------------
KEY_FILE=
SHEET_NAME=GrindAlgo Tracker
DRIVE_FOLDER=GrindAlgo Reports
EMAIL_RECIPIENT=
GMAIL_APP_PASSWORD=

# ------------------------------
# Application
# ------------------------------
FRONTEND_URL=http://localhost:3000
CORS_ALLOWED_ORIGINS=http://localhost:3000
TZ=Africa/Lagos

# ------------------------------
# Ports
# ------------------------------
APP_PORT=8000
